# Copy this file to .env and fill in your values
# cp .env.example .env

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — get from platform.openai.com
OPENAI_API_KEY=sk-...

# Path to the navigation_stack repo on your machine
NAV_STACK_PATH=~/Documents/navigation_stack

# Path to downloaded RUGD dataset root (folder containing train/, val/, test/)
RUGD_DATA_PATH=~/Documents/datasets/rugd

# SAM3 checkpoint folder (contains sam3.pt and bpe_simple_vocab_16e6.txt.gz)
SAM3_CKPT_PATH=~/Documents/navigation_stack/ws/src/perception/ckpt/sam3
